{
  "name": "ai-office",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "node packages/server/dist/index.js",
    "dev:server": "npm run dev -w @ai-office/server",
    "dev:web": "npm run dev -w @ai-office/web",
    "qa:post-deploy": "npm run qa:post-deploy -w @ai-office/server",
    "docker:build": "docker build -t ai-office .",
    "docker:run": "docker compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
